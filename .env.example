# ===================================================================
#  MATCHMAKING — env vars (copier en .env et remplir)
# ===================================================================

# ---------- Root ----------
NODE_ENV=development

# ---------- Database ----------
DATABASE_URL="postgresql://matchmaking:matchmaking@localhost:5432/matchmaking?schema=public"

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379"

# ---------- Discord (Bot + OAuth) ----------
# Crée une app sur https://discord.com/developers/applications
# Le bot ET l'OAuth partagent la même application Discord.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""                # serveur Discord de dev
DISCORD_ADMIN_ROLE_ID=""           # rôle staff autorisé à force-validate
DISCORD_MATCH_CATEGORY_ID=""       # catégorie où seront créés les channels de match

# OAuth callback (doit matcher dans l'app Discord > OAuth2 > Redirects)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""                 # openssl rand -hex 32

# ---------- Storage (S3-compatible) ----------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="matchmaking-screenshots"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_PUBLIC_URL="http://localhost:9000/matchmaking-screenshots"

# ---------- OCR ----------
OCR_PROVIDER="gpt4o"               # gpt4o | gcv
OPENAI_API_KEY=""
GOOGLE_CLOUD_VISION_KEY=""

# ---------- Internal API (bot ↔ api) ----------
INTERNAL_API_SECRET=""             # HMAC shared secret, openssl rand -hex 32
API_PORT=4000
WEB_PORT=3000
BOT_LOG_LEVEL="info"